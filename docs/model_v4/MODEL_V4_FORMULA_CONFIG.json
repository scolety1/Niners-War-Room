  "missing_evidence_policy": {
    "established_veteran_missing_value_components_are_not_zero_production": true,
    "missing_component_uncertainty_penalty_rate": 0.2,
    "max_missing_component_uncertainty_penalty": 8.0,
    "applies_only_to_evidence_adjusted_missing_not_zero": true,
    "reason": "Missing critical evidence should not be scored as zero production, but it also should not become a ranking advantage over complete high-confidence evidence."
  },
  "lifecycle_rules": {
    "incoming_rookie": {
      "allowed_prior_inputs": [
        "draft_capital",
        "prospect_profile",
        "college_production_context"
      ],
      "rookie_prior_weight": 1.0,
      "nfl_evidence_weight": 0.0,
      "review_requirement": "incoming rookies use sourced draft/prospect lane, not veteran production",
      "missing_prior_policy": "incoming rookies with missing production, first-down, usage, snap, projection, age, and young-prior evidence stay weak/review until sourced rookie board data exists"
    },
    "year_one_nfl_bridge": {
      "rookie_prior_weight_cap": 0.45,
      "nfl_evidence_weight_floor": 0.55,
      "decay_rule": "prior remains meaningful but secondary after NFL evidence begins"
    },
    "year_two_nfl_bridge": {
      "rookie_prior_weight_cap": 0.25,
      "nfl_evidence_weight_floor": 0.75,
      "decay_rule": "prior becomes smaller unless NFL evidence is missing"
    },
    "year_three_nfl_bridge": {
      "rookie_prior_weight_cap": 0.1,
      "nfl_evidence_weight_floor": 0.9,
      "decay_rule": "prior is tiny and must not override established NFL evidence"
    },
    "established_veteran": {
      "draft_capital_weight": 0,
      "prospect_profile_weight": 0,
      "review_requirement": "draft capital is display-only and cannot score established veterans"
    }
  },
