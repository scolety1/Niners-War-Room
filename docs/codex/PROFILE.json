{
  "name": "real-product",
  "description": "Strict profile for real product repositories.",
  "projectType": "full-stack-web",
  "riskTier": "production-adjacent",
  "capabilities": {
    "canEditPackageFiles": false,
    "canAddDependencies": false,
    "canEditBackendCode": false,
    "canEditMigrations": false,
    "canEditAuthPolicy": false,
    "canEditDeploymentConfig": false,
    "canUseNetworkApis": false,
    "canOpenPullRequests": false,
    "canDeploy": false
  },
  "defaultRounds": 6,
  "branchPrefix": "codex/niners-war-room",
  "maxChangedFiles": 8,
  "maxBatchChangedFiles": 8,
  "model": "gpt-5.5",
  "models": {
    "implement": ["gpt-5.5", "gpt-5.3-codex", "gpt-5.4"],
    "review": ["gpt-5.5", "gpt-5.4"],
    "planner": ["gpt-5.5", "gpt-5.4"],
    "checkpoint": ["gpt-5.5", "gpt-5.4"],
    "simon": ["gpt-5.5", "gpt-5.4"]
  },
  "timeouts": {
    "codex": 2400,
    "implement": 2400,
    "review": 1500,
    "build": 900,
    "planner": 900,
    "checkpoint": 900,
    "simon": 900,
    "visual": 900,
    "joey": 300,
    "debug": 300,
    "guardrails": 180,
    "rateLimitCooldownSeconds": 3600,
    "rateLimitMaxCooldowns": 6
  },
  "visualPaths": ["/", "/Import_Review", "/Team", "/War_Board", "/Trade_Central", "/Draft_Room", "/League_Intel"],
  "allowedPaths": [
    "app/",
    "src/",
    "tests/",
    "scripts/",
    "sample_data/",
    "docs/codex/",
    "docs/ai/",
    "README.md",
    "DATA_MODEL.md",
    "MODEL_SPEC.md",
    "USER_WORKFLOW.md",
    "MISSION.md",
    "RUN_POLICY.md",
    "TASK_QUEUE.md",
    "AGENTS.md"
  ],
  "blockedPaths": [
    "data_packs/",
    "dist/",
    "build/",
    "coverage/",
    ".env",
    ".venv/",
    "pyproject.toml",
    "requirements.txt",
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json"
  ],
  "blockedTerms": [
    "api key",
    "bearer token",
    "secret",
    "openai",
    "anthropic",
    "gemini",
    "scrape",
    "beautifulsoup",
    "selenium",
    "process.env",
    "import.meta.env"
  ],
  "buildDirectory": ".",
  "buildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\codex-static-check.ps1"
}
