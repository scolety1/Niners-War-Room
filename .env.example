# Copy to `.env` for local runs. Do not commit `.env`.
#
# Sleeper is public/read-only and does not require an API key.
NINERS_SLEEPER_LEAGUE_ID=1344772855908290560
SLEEPER_API_BASE=https://api.sleeper.app/v1

# CollegeFootballData requires a user API key if/when we run live CFBD imports.
# Leave blank until a live import is explicitly approved.
CFBD_API_KEY=
CFBD_API_BASE=https://api.collegefootballdata.com

# Paid/commercial feeds stay disabled until terms/exports are explicitly approved.
SPORTSDATAIO_API_KEY=
SPORTSDATAIO_API_BASE=https://api.sportsdata.io
PFF_EXPORT_ROOT=
ROTOWIRE_EXPORT_ROOT=

# API safety knobs.
MODEL_V4_LIVE_API_ENABLED=false
MODEL_V4_API_CACHE_ROOT=local_exports/api_cache
MODEL_V4_API_TIMEOUT_SECONDS=30
MODEL_V4_MAX_REQUESTS_PER_MINUTE=60
