      "usable",
      "review",
      "weak",
      "blocked"
    ],
    "confidence_is_score_trust_not_player_value": true,
    "missing_critical_evidence_blocks_trust": true,
    "missing_optional_evidence_retains_warning": true,
    "proxy_heavy_role_evidence_retains_warning": true,
    "local_baseline_projection_is_not_independent_forecast": true,
    "unsourced_healthy_injury_context_cannot_boost_confidence": true,
